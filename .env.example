# Copy to .env.local for local testing — set the same keys in Vercel → Settings → Environment Variables

# Required for contact form, lead magnet popup, and newsletter (optional until you need forms)
RESEND_API_KEY=
RESEND_FROM_EMAIL=AlphaX Studio <mail@yourdomain.com>

# Optional — live Calendly event URL (must exist in your Calendly account)
# Optional override (default: https://calendly.com/alphaxdezignerzstudio-sales/30min)
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/YOUR-USERNAME/YOUR-EVENT-SLUG
